  "subskills": [
    {
      "name": "handoff-pack",
      "kind": "subskill",
      "job": "Materialize a fiction project pack (brief.json, bible.md, world/, plot/, chapters/, continuity/ledger.json) with schema validate so phase skills share one filesystem contract.",
      "pulls_from": [
        "chapter-writing",
        "worldbuilding",
        "plot-structure",
        "novel-creator",
        "story-architecture"
      ]
    },
    {
      "name": "verify-gate",
      "kind": "subskill",
      "job": "Independent false-done gate: required artifacts exist, claims coverage, min word counts, continuity ledger dirty=false, AI-sermon heuristics optional \u2014 scripts decide PASS/FAIL, not chat self-grade.",
      "pulls_from": [
        "chapter-writing",
        "story-review",
        "novel-creator"
      ]
    },
    {
      "name": "continuity-bridge",
      "kind": "subskill",
      "job": "Diff and merge continuity ledgers across world/plot/chapter/review stages; block superskill advance when unresolved contradictions remain.",
      "pulls_from": [
        "worldbuilding",
        "plot-structure",
        "chapter-writing",
        "story-review"
      ]
    },
    {
      "name": "assist-mode-router",
      "kind": "subskill",
      "job": "Route autonomous vs assisted creative writing: gate AskUserQuestion, default lengths, and which member skill owns novel planning (novel-creator vs novel-writer) without Storybook/user-story misfires.",
      "pulls_from": [
        "novel-creator",
        "novel-writer",
        "creative-writing",
        "writing-principles"
      ]
    }
  ],
  "superskill": {
    "name": "assisted-novel-forge",
    "kind": "superskill",
    "job": "Run an autonomous-or-assisted creative-writing pipeline: intake \u2192 world/plot/architecture \u2192 novel plan \u2192 chapters \u2192 craft \u2192 review, with handoff packs and verify gates so agents cannot false-done a manuscript.",
    "phases": [
      "0. intake + mode (autonomous|assisted) + non-trigger guard (not Storybook UI, not agile user-stories, not scientific manuscripts)",
      "1. writing-principles \u2014 craft constraints / voice contract",
      "2. worldbuilding \u2014 canon places/rules/factions",
      "3. plot-structure \u2014 arc beats + stakes ladder",
      "4. story-architecture (story-planning) \u2014 chapter/scene architecture",
      "5. novel-creator OR novel-writer \u2014 full-novel plan (assisted asks; autonomous generates)",
      "6. chapter-writing \u2014 outline-then-prose per chapter",
      "7. creative-writing-craft \u2014 prose craft pass",
      "8. story-review \u2014 critique + revision targets",
      "9. greyhaven creative-writing \u2014 optional assisted coach pass",
      "10. verify-gate + metric rollup \u2014 refuse done until pass"
    ],
    "wires": [
      "writing-principles-upgraded",
      "worldbuilding-upgraded",
      "plot-structure-upgraded",
      "story-architecture-upgraded",
      "novel-creator-upgraded",
      "novel-writer-upgraded",
      "chapter-writing-upgraded",
      "creative-writing-craft-upgraded",
      "story-review-upgraded",
      "creative-writing-upgraded",
      "handoff-pack",
      "verify-gate",
      "continuity-bridge",
      "assist-mode-router"
    ],
    "modes": {
      "assisted": "AskUserQuestion at phase boundaries; never overwrite user canon without confirm",
      "autonomous": "Generate full pipeline with checkpoints written to project/; still must pass verify-gate"
    }
  },
